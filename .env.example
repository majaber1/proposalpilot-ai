# ProposalPilot AI - Environment Configuration
# Copy this file to .env and update the values

# ===========================================
# APPLICATION
# ===========================================
APP_NAME="ProposalPilot AI"
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# ===========================================
# SECURITY
# ===========================================
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ADMIN_EMAIL=admin@demo.com
ADMIN_PASSWORD=demo123

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL=postgresql://proposalpilot:proposalpilot123@postgres:5432/proposalpilotdb
POSTGRES_DB=proposalpilotdb
POSTGRES_USER=proposalpilot
POSTGRES_PASSWORD=proposalpilot123

# ===========================================
# AI / OLLAMA CONFIGURATION
# ===========================================
# Ollama server URL
OLLAMA_BASE_URL=http://ollama:11434

# Default model - change to switch AI model
# Options: qwen2.5:7b-instruct, llama3.1:8b, mistral:7b
OLLAMA_MODEL=qwen2.5:7b-instruct

# AI generation settings
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=4096
AI_TIMEOUT_SECONDS=120

# ===========================================
# VECTOR DATABASE (ChromaDB)
# ===========================================
CHROMADB_HOST=chromadb
CHROMADB_PORT=8001

# ===========================================
# FILE UPLOAD SETTINGS
# ===========================================
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=/app/uploads
ALLOWED_EXTENSIONS=pdf,docx,doc,txt

# ===========================================
# FRONTEND (Next.js)
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME="ProposalPilot AI"
NEXT_PUBLIC_APP_TAGLINE="AI-powered proposal assistant"

# ===========================================
# CORS SETTINGS
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
